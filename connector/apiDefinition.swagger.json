{
  "swagger": "2.0",
  "info": {
    "title": "NC Governor Comms Agent",
    "description": "AI-powered news clips, remarks search, and transcript proofreading for the NC Governor's Communications Office.",
    "version": "1.0.0",
    "contact": {
      "name": "NC DIT AI Office"
    }
  },
  "host": "nc-comms-agent-dev-apim.azure-api.net",
  "basePath": "/comms",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "apim_key": {
      "type": "apiKey",
      "in": "header",
      "name": "Ocp-Apim-Subscription-Key"
    }
  },
  "security": [
    {
      "apim_key": []
    }
  ],
  "paths": {
    "/clips/query": {
      "post": {
        "operationId": "QueryClips",
        "summary": "Search news clips",
        "description": "Search for news clips mentioning the Governor. Send an empty query or 'latest' to get the most recent clips. Provide a topic or question for semantic search.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ClipsQueryRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching news clips",
            "schema": {
              "$ref": "#/definitions/ClipsQueryResponse"
            }
          },
          "400": {
            "description": "Invalid request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/remarks/query": {
      "post": {
        "operationId": "QueryRemarks",
        "summary": "Search Governor's remarks",
        "description": "Semantic search over the Governor's historical speeches and remarks. Returns relevant excerpts and an AI-synthesized summary with direct quotes and citations.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RemarksQueryRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results with optional AI synthesis",
            "schema": {
              "$ref": "#/definitions/RemarksQueryResponse"
            }
          },
          "400": {
            "description": "Invalid request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/proofread": {
      "post": {
        "operationId": "ProofreadTranscript",
        "summary": "Proofread a transcript",
        "description": "AI-powered cleanup of faulty transcripts from ASR or OCR. Fixes homophones, garbled text, punctuation, proper nouns, and number formatting while preserving original meaning and tone.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ProofreadRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Corrected transcript with change details",
            "schema": {
              "$ref": "#/definitions/ProofreadResponse"
            }
          },
          "400": {
            "description": "Invalid request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "ClipsQueryRequest": {
      "type": "object",
      "required": ["query"],
      "properties": {
        "query": {
          "type": "string",
          "description": "Search topic or question. Use empty string or 'latest' for most recent clips."
        },
        "dateFrom": {
          "type": "string",
          "description": "Start date filter (ISO 8601, e.g. 2026-03-01)"
        },
        "dateTo": {
          "type": "string",
          "description": "End date filter (ISO 8601, e.g. 2026-03-23)"
        },
        "top": {
          "type": "integer",
          "description": "Max results to return (default 10, max 50)",
          "default": 10
        }
      }
    },
    "ClipsQueryResponse": {
      "type": "object",
      "properties": {
        "clips": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NewsClip"
          }
        },
        "count": {
          "type": "integer",
          "description": "Number of results returned"
        }
      }
    },
    "NewsClip": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "description": "Source article URL"
        },
        "outlet": {
          "type": "string",
          "description": "News outlet name"
        },
        "title": {
          "type": "string",
          "description": "Article headline"
        },
        "publishedAt": {
          "type": "string",
          "description": "Publication date (ISO 8601)"
        },
        "lede": {
          "type": "string",
          "description": "First paragraph of the article"
        },
        "mentionContext": {
          "type": "string",
          "description": "Sentence containing first Governor mention"
        }
      }
    },
    "RemarksQueryRequest": {
      "type": "object",
      "required": ["query"],
      "properties": {
        "query": {
          "type": "string",
          "description": "Topic or question to search across the Governor's remarks"
        },
        "event": {
          "type": "string",
          "description": "Filter by event name (e.g. 'State of the State')"
        },
        "dateFrom": {
          "type": "string",
          "description": "Start date filter (ISO 8601)"
        },
        "dateTo": {
          "type": "string",
          "description": "End date filter (ISO 8601)"
        },
        "top": {
          "type": "integer",
          "description": "Max source chunks to return (default 10, max 30)",
          "default": 10
        },
        "synthesize": {
          "type": "boolean",
          "description": "Whether to generate an AI summary with citations (default true)",
          "default": true
        }
      }
    },
    "RemarksQueryResponse": {
      "type": "object",
      "properties": {
        "synthesis": {
          "type": "string",
          "description": "AI-generated summary with direct quotes and citations"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RemarksChunk"
          }
        },
        "count": {
          "type": "integer",
          "description": "Number of source chunks returned"
        }
      }
    },
    "RemarksChunk": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "remarkId": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "description": "Speech or remarks title"
        },
        "date": {
          "type": "string",
          "description": "Date delivered (YYYY-MM-DD)"
        },
        "event": {
          "type": "string",
          "description": "Event name"
        },
        "venue": {
          "type": "string",
          "description": "Venue where delivered"
        },
        "chunkIndex": {
          "type": "integer"
        },
        "chunkText": {
          "type": "string",
          "description": "Excerpt text from the remarks"
        },
        "topicTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Inferred topic tags"
        }
      }
    },
    "ProofreadRequest": {
      "type": "object",
      "required": ["transcript"],
      "properties": {
        "transcript": {
          "type": "string",
          "description": "Raw transcript text to proofread (max 100,000 characters)"
        },
        "speakerLabels": {
          "type": "boolean",
          "description": "Normalize speaker labels to 'Speaker Name:' format (default false)",
          "default": false
        }
      }
    },
    "ProofreadResponse": {
      "type": "object",
      "properties": {
        "corrected": {
          "type": "string",
          "description": "Fully corrected transcript"
        },
        "changes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProofreadChange"
          }
        },
        "summary": {
          "type": "string",
          "description": "Human-readable summary of corrections made"
        }
      }
    },
    "ProofreadChange": {
      "type": "object",
      "properties": {
        "original": {
          "type": "string",
          "description": "Original text"
        },
        "corrected": {
          "type": "string",
          "description": "Corrected text"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Confidence level of the correction"
        },
        "reason": {
          "type": "string",
          "description": "Brief explanation of the correction"
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string",
          "description": "Human-readable error message"
        }
      }
    }
  }
}
