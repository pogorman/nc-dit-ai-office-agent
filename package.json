{
  "name": "nc-dit-ai-office-agent",
  "version": "0.1.0",
  "description": "Serverless AI platform for NC Governor's Communications Office — news clips, remarks search, transcript proofreading",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "start": "npm run build && func start",
    "prestart": "npm run build"
  },
  "dependencies": {
    "@azure/cosmos": "4.9.2",
    "@azure/functions": "4.11.2",
    "@azure/identity": "4.13.1",
    "@azure/keyvault-secrets": "4.10.0",
    "@azure/openai": "2.0.0",
    "@azure/search-documents": "12.2.0",
    "@azure/storage-blob": "12.31.0",
    "openai": "6.32.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "azure-functions-core-tools": "4.8.0",
    "rimraf": "6.0.1",
    "typescript": "6.0.2"
  }
}
