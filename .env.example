# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
GPT4O_DEPLOYMENT_NAME=gpt-4o
EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# Azure AI Search
AZURE_AI_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net

# Cosmos DB
COSMOS_DB_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443

# Storage
STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net

# Key Vault (for secrets like Bing News Search API key)
BING_NEWS_SEARCH_KEY_VAULT_URL=https://<your-keyvault>.vault.azure.net
